NODE_ENV=development
PORT=3000

# Supabase Postgres connection string (used purely as managed Postgres, no RLS/Auth)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Cloudflare R2 (S3-compatible, scratch space for uploaded audio only)
# Not Supabase Storage: its Free plan hard-caps uploads at 50MB.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=recordings

# Google OAuth (custom flow, not Supabase Auth) - scope: openid email profile drive.file
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Comma-separated allowlist of admin emails, checked at login
ADMIN_EMAILS=you@example.com

# Session JWT signing secret (>=32 chars)
JWT_SECRET=

# Base64-encoded 32-byte key for AES-256-GCM encryption of provider keys / Drive refresh tokens
MASTER_ENCRYPTION_KEY=

FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3000

DEFAULT_USAGE_LIMIT_MINUTES=180

# STT provider keys are stored encrypted in the DB via the admin UI, not env vars.

# Internal voice-embedding microservice (voice-service/), server-to-server only.
VOICE_SERVICE_URL=http://localhost:8001
VOICE_SERVICE_SECRET=
VOICE_MATCH_THRESHOLD=0.75
